# CISO Assistant instance URL (no /api suffix)
CISO_ASSISTANT_URL=https://localhost:8443

# Personal Access Token (create from your user profile in CISO Assistant)
CISO_ASSISTANT_TOKEN=

# Or use email/password login instead of a token
# CISO_ASSISTANT_EMAIL=admin@example.com
# CISO_ASSISTANT_PASSWORD=

# Set to false for self-signed certificates (common in local Docker)
CISO_ASSISTANT_VERIFY_SSL=false
